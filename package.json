{
  "name": "mcp-pulse",
  "version": "1.0.0",
  "description": "Real-time monitoring & observability dashboard for Model Context Protocol (MCP) servers",
  "author": "Sergiu Pogor",
  "license": "MIT",
  "homepage": "https://github.com/SergiuPogor/mcp-pulse",
  "repository": {
    "type": "git",
    "url": "https://github.com/SergiuPogor/mcp-pulse.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "monitoring",
    "observability",
    "dashboard",
    "ai",
    "llm",
    "developer-tools",
    "mcp-server",
    "real-time"
  ],
  "type": "module",
  "bin": {
    "mcp-pulse": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --fix && prettier src --write",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "clsx": "^2.1.0",
    "commander": "^11.1.0",
    "date-fns": "^3.3.1",
    "dot": "^1.1.3",
    "dotenv": "^17.0.0",
    "express": "^4.18.3",
    "http-proxy-middleware": "^3.0.0",
    "json-schema-to-typescript": "^15.0.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "zx": "^8.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^4.17.21",
    "@types/http-proxy-middleware": "^1.0.0",
    "@types/node": "^20.11.24",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^1.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts"
  ]
}
