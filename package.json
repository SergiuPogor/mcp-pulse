{
  "name": "mcp-pulse",
  "version": "1.0.0",
  "description": "Real-time monitoring & observability dashboard for Model Context Protocol (MCP) servers",
  "author": "Phantom Fall Studios",
  "license": "MIT",
  "homepage": "https://github.com/phantomfallstudios/mcp-pulse",
  "repository": {
    "type": "git",
    "url": "https://github.com/phantomfallstudios/mcp-pulse.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "monitoring",
    "observability",
    "dashboard",
    "ai",
    "llm",
    "developer-tools",
    "mcp-server",
    "real-time"
  ],
  "type": "module",
  "bin": {
    "mcp-pulse": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --fix && prettier src --write",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "express": "^4.18.3",
    "ws": "^8.16.0",
    "uuid": "^9.0.1",
    "commander": "^11.1.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "redis": "^10.6.0",
    "http-proxy-middleware": "^2.0.6",
    "json-schema-to-typescript": "^13.1.2",
    "zx": "^7.2.3",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "dot": "^1.1.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/uuid": "^9.0.8",
    "@types/node": "^20.11.24",
    "@types/http-proxy-middleware": "^1.0.0",
    "typescript": "^5.4.2",
    "tsx": "^4.7.1",
    "vitest": "^1.3.1",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "@eslint/js": "^9.0.0",
    "eslint-config-prettier": "^9.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": ["linux", "darwin", "win32"],
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts"
  ]
}
